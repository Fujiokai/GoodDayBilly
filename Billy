	if autoRebirthEnabled      then table.insert(active, "Rebirth") end
	if autoAscendEnabled       then table.insert(active, "Ascension") end
	if autoRarityRollEnabled   then table.insert(active, "RarityRoll") end
	if autoBambooEnabled       then table.insert(active, "Bamboo") end
	if autoEverBloomEnabled    then table.insert(active, "Everbloom") end
	if autoFishEnabled         then table.insert(active, "Fish") end

	if #active == 0 then
		statusLabel.Text = "> status: idle"
	else
		local label
		if #active <= 3 then
			label = table.concat(active, ", ")
		else
			local shown = {active[1], active[2], active[3]}
			local remaining = #active - 3
			label = table.concat(shown, ", ") .. " +" .. tostring(remaining) .. " more"
		end
		statusLabel.Text = "> status: running (" .. label .. ")"
	end
