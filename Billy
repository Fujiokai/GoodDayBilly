local crtAnimating = false

local function crtOff(targetFrame, callback)
	if not targetFrame then
		if callback then callback() end
		return
	end
	crtAnimating = true
	targetFrame.ClipsDescendants = true

	local flash = Instance.new("Frame")
	flash.Size = UDim2.new(1, 0, 1, 0)
	flash.Position = UDim2.new(0, 0, 0, 0)
	flash.BackgroundColor3 = Color3.new(1, 1, 1)
	flash.BorderSizePixel = 0
	flash.Parent = targetFrame

	local mask = Instance.new("Frame")
	mask.Size = UDim2.new(1, 0, 1, 0)
	mask.Position = UDim2.new(0, 0, 0, 0)
	mask.BackgroundColor3 = Color3.new(0, 0, 0)
	mask.BorderSizePixel = 0
	mask.BackgroundTransparency = 1
	mask.Parent = targetFrame

	local info1    = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local info2    = TweenInfo.new(0.10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local infoMask = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	TweenService:Create(mask, infoMask, {BackgroundTransparency = 0}):Play()

	local tween1 = TweenService:Create(flash, info1, {
		Size = UDim2.new(1, 0, 0, 3),
		Position = UDim2.new(0, 0, 0.5, -1)
	})
	local tween2 = TweenService:Create(flash, info2, {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0)
	})

	tween1:Play()
	tween1.Completed:Wait()
	tween2:Play()
	tween2.Completed:Wait()

	flash:Destroy()
	mask:Destroy()
	targetFrame.ClipsDescendants = false
	crtAnimating = false

	if callback then callback() end
end

local function crtOn(targetFrame, callback)
	if not targetFrame then
		if callback then callback() end
		return
	end
	crtAnimating = true
	targetFrame.ClipsDescendants = true

	local mask = Instance.new("Frame")
	mask.Size = UDim2.new(1, 0, 1, 0)
	mask.Position = UDim2.new(0, 0, 0, 0)
	mask.BackgroundColor3 = Color3.new(0, 0, 0)
	mask.BorderSizePixel = 0
	mask.BackgroundTransparency = 0
	mask.Parent = targetFrame

	local flash = Instance.new("Frame")
	flash.Size = UDim2.new(0, 0, 0, 0)
	flash.Position = UDim2.new(0.5, 0, 0.5, 0)
	flash.BackgroundColor3 = Color3.new(1, 1, 1)
	flash.BorderSizePixel = 0
	flash.Parent = targetFrame

	local info1    = TweenInfo.new(0.10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local info2    = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local infoMask = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	local tween1 = TweenService:Create(flash, info1, {
		Size = UDim2.new(1, 0, 0, 3),
		Position = UDim2.new(0, 0, 0.5, -1)
	})
	local tween2 = TweenService:Create(flash, info2, {
		Size = UDim2.new(1, 0, 1, 0),
		Position = UDim2.new(0, 0, 0, 0)
	})
	local tweenMask = TweenService:Create(mask, infoMask, {BackgroundTransparency = 1})

	tween1:Play()
	tween1.Completed:Wait()
	tween2:Play()
	tweenMask:Play()
	tween2.Completed:Wait()
	tweenMask.Completed:Wait()

	flash:Destroy()
	mask:Destroy()
	targetFrame.ClipsDescendants = false
	crtAnimating = false

	if callback then callback() end
end

local isMinimized = false

local function minimizeConsole()
	if isMinimized or crtAnimating then return end
	lastFramePosition = frame.Position
	lastFrameSize     = frame.Size

	crtOff(frame, function()
		local centerX = frame.Position.X.Offset + frame.Size.X.Offset / 2
		local centerY = frame.Position.Y.Offset + frame.Size.Y.Offset / 2
		local tweenShrink = TweenService:Create(
			frame,
			TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{
				Size = UDim2.new(0, 0, 0, 0),
				Position = UDim2.new(0, centerX, 0, centerY),
			}
		)
		tweenShrink:Play()
		tweenShrink.Completed:Wait()

		frame.Visible = false
		maxBar.Visible = true
		isMinimized = true
	end)
end

local function maximizeConsole()
	if not isMinimized or crtAnimating then return end
	maxBar.Visible = false

	local centerX = lastFramePosition.X.Offset + lastFrameSize.X.Offset / 2
	local centerY = lastFramePosition.Y.Offset + lastFrameSize.Y.Offset / 2

	frame.Size = UDim2.new(0, 0, 0, 0)
	frame.Position = UDim2.new(0, centerX, 0, centerY)
	frame.Visible = true

	crtOn(frame, function()
		local tweenExpand = TweenService:Create(
			frame,
			TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{
				Size = lastFrameSize,
				Position = lastFramePosition,
			}
		)
		tweenExpand:Play()
		tweenExpand.Completed:Wait()
		isMinimized = false
	end)
end

minimizeButton.MouseButton1Click:Connect(minimizeConsole)
maxBar.MouseButton1Click:Connect(maximizeConsole)

-- Idle fade
local IDLE_TIME = 10
local lastInteraction = os.clock()
local isIdle = false

local function applyIdleAlpha(idle)
	local alpha = idle and 0.4 or 0
	frame.BackgroundTransparency = alpha
	sidePanel.BackgroundTransparency = alpha
	mainLogScroll.BackgroundTransparency = alpha
	spamLogScroll.BackgroundTransparency = alpha
	maxBar.BackgroundTransparency = idle and 0.7 or 0.5
end

local function markActive()
	lastInteraction = os.clock()
	if isIdle then
		isIdle = false
		applyIdleAlpha(false)
	end
end

UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	markActive()
end)

UserInputService.InputChanged:Connect(function(input, gp)
	if gp then return end
	if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch
		or input.UserInputType == Enum.UserInputType.Gamepad1 then
		markActive()
	end
end)

