local function addRuneFromInput()
	local text = (runeInputBox and runeInputBox.Text or ""):gsub("%s+", "")
	if text == "" then return end

	for _, v in ipairs(currentRunes) do
		if type(v) == "table" and string.lower(v.name) == string.lower(text) then
			logMain("> Rune already in list: " .. text)
			return
		elseif type(v) == "string" and string.lower(v) == string.lower(text) then
			logMain("> Rune already in list: " .. text)
			return
		end
	end

	table.insert(currentRunes, { name = text, enabled = true })
	logMain("> Rune added: " .. text)
	refreshRunesUI()
end

