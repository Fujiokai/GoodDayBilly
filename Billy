local mainLogScroll, mainLogLayout = createLogScroll("MainLog")
local spamLogScroll, spamLogLayout = createLogScroll("SpamLog")
spamLogScroll.Visible = false

local MAX_LOGS_MAIN = 500
local MAX_LOGS_SPAM = 800
local mainLogCount  = 0
local spamLogCount  = 0

local lastMainText, lastMainLabel, lastMainCount = nil, nil, 0
local lastSpamText, lastSpamLabel, lastSpamCount = nil, nil, 0

local function newLogLabel(scroll, layout, text, color)
	local line = Instance.new("TextLabel")
	line.Name = "LogLine"
	line.BackgroundTransparency = 1
	line.Size = UDim2.new(1, 0, 0, 16)
	line.Font = Enum.Font.Code
	line.TextSize = 13
	line.TextXAlignment = Enum.TextXAlignment.Left
	line.TextColor3 = color or COLOR_TEXT_DIM
	line.Text = text
	line.Parent = scroll
	return line
end

local function trimLogs(scroll, isMain)
	if isMain then
		if mainLogCount <= MAX_LOGS_MAIN then return end
		for _, child in ipairs(scroll:GetChildren()) do
			if child:IsA("TextLabel") and child.Name == "LogLine" then
				child:Destroy()
				mainLogCount -= 1
				if mainLogCount <= MAX_LOGS_MAIN then break end
			end
		end
	else
		if spamLogCount <= MAX_LOGS_SPAM then return end
		for _, child in ipairs(scroll:GetChildren()) do
			if child:IsA("TextLabel") and child.Name == "LogLine" then
				child:Destroy()
				spamLogCount -= 1
				if spamLogCount <= MAX_LOGS_SPAM then break end
			end
		end
	end
end

local function logMain(text)
	if lastMainText == text and lastMainLabel and lastMainLabel.Parent == mainLogScroll then
		lastMainCount += 1
		lastMainLabel.Text = text .. " x" .. tostring(lastMainCount)
	else
		lastMainText  = text
		lastMainCount = 1
		lastMainLabel = newLogLabel(mainLogScroll, mainLogLayout, text, COLOR_TEXT_DIM)
		mainLogCount += 1
		trimLogs(mainLogScroll, true)
		task.defer(function()
			local contentY = mainLogLayout.AbsoluteContentSize.Y
			local visibleY = mainLogScroll.AbsoluteSize.Y
			if contentY > visibleY then
				mainLogScroll.CanvasPosition = Vector2.new(0, contentY - visibleY)
			end
		end)
	end
end

local function logSpam(text)
	if lastSpamText == text and lastSpamLabel and lastSpamLabel.Parent == spamLogScroll then
		lastSpamCount += 1
		lastSpamLabel.Text = text .. " x" .. tostring(lastSpamCount)
	else
		lastSpamText  = text
		lastSpamCount = 1
		lastSpamLabel = newLogLabel(spamLogScroll, spamLogLayout, text, Color3.fromRGB(120, 160, 240))
		spamLogCount += 1
		trimLogs(spamLogScroll, false)
		task.defer(function()
			local contentY = spamLogLayout.AbsoluteContentSize.Y
			local visibleY = spamLogScroll.AbsoluteSize.Y
			if contentY > visibleY then
				spamLogScroll.CanvasPosition = Vector2.new(0, contentY - visibleY)
			end
		end)
	end
end

local function setActiveLogTab(mainActive)
	if mainActive then
		mainLogScroll.Visible = true
