--------------------------------------------------------

local panelExpanded = false
local animatingPanel = false

local function animatePanel(expand)
	if animatingPanel then return end
	animatingPanel = true
	panelExpanded = expand

	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	if expand then
		sidePanel.Visible = true
		sidePanel.Size = UDim2.new(0, 0, 1, 0)

		TweenService:Create(frame, tweenInfo, {
			Size = UDim2.new(0, BASE_WIDTH + PANEL_WIDTH, 0, FRAME_HEIGHT)
		}):Play()

		TweenService:Create(mainArea, tweenInfo, {
			Position = UDim2.new(0, PANEL_WIDTH, 0, 0),
			Size = UDim2.new(1, -PANEL_WIDTH, 1, 0)
		}):Play()

		TweenService:Create(sidePanel, tweenInfo, {
			Size = UDim2.new(0, PANEL_WIDTH, 1, 0)
		}):Play()

		expandButton.Text = "<"
		task.delay(0.25, function() animatingPanel = false end)
	else
		local tweenSide = TweenService:Create(sidePanel, tweenInfo, {
			Size = UDim2.new(0, 0, 1, 0)
		})
		tweenSide:Play()

		TweenService:Create(frame, tweenInfo, {
			Size = UDim2.new(0, BASE_WIDTH, 0, FRAME_HEIGHT)
		}):Play()

		TweenService:Create(mainArea, tweenInfo, {
			Position = UDim2.new(0, 0, 0, 0),
			Size = UDim2.new(1, 0, 1, 0)
		}):Play()

		expandButton.Text = ">"
		tweenSide.Completed:Connect(function()
			sidePanel.Visible = false
			animatingPanel = false
		end)
	end
end

expandButton.MouseButton1Click:Connect(function()
	animatePanel(not panelExpanded)
end)

