local function buildUpgradeGroupFromFolder(folder)
	local group = {
		id       = folder.Name,
		title    = folder.Name,
		upgrades = {},
		enabled  = false,
	}

	local mainPart = folder:FindFirstChild("MainPart")
	if not mainPart then
		return nil
	end

	local surfaceGui
	for _, inst in ipairs(mainPart:GetChildren()) do
		if inst:IsA("SurfaceGui") then
			surfaceGui = inst
			break
		end
	end
	if not surfaceGui then
		return nil
	end

	local mainFrame = surfaceGui:FindFirstChild("MainFrame")
	if not mainFrame then
		return nil
	end

	-- Title
	local titleFrame = mainFrame:FindFirstChild("Title")
	if titleFrame then
		local titleLabel = titleFrame:FindFirstChild("Title")
		if titleLabel and titleLabel:IsA("TextLabel") then
			if titleLabel.Text and titleLabel.Text ~= "" then
				group.title = titleLabel.Text
			end
		end
	end

	-- Upgrades list
	local upgradesFrame = mainFrame:FindFirstChild("Upgrades")
	if not upgradesFrame then
		return nil
	end
	local scrollFrame = upgradesFrame:FindFirstChild("ScrollFrame")
	if not scrollFrame then
		return nil
	end

	for _, child in ipairs(scrollFrame:GetChildren()) do
		if child:IsA("Frame") or child:IsA("TextButton") or child:IsA("ImageButton") then
			table.insert(group.upgrades, child.Name)
		end
	end

	if #group.upgrades == 0 then
		return nil
	end

	return group
end

local function scanUpgradeGroupsAndCreateUI()
	UpgradeGroups = {}

	for _, child in ipairs(workspace:GetChildren()) do
		if child.Name:match("^Upgrades%d+$") then
			local group = buildUpgradeGroupFromFolder(child)
			if group then
				local toggle = createToggleRow(sidePanel, group.title, false, function(on)
					group.enabled = on
					logMain("> " .. group.title .. " Upgrades: " .. (on and "ON" or "OFF"))
					updateStatus()
					if on then
						startUpgradesLoopIfNeeded()
					end
				end)
				group.toggle = toggle
				table.insert(UpgradeGroups, group)
			end
		end
	end

	if #UpgradeGroups == 0 then
		logMain("> Dynamic Upgrades: no Upgrades folders found in workspace.")
	else
		logMain("> Dynamic Upgrades: loaded " .. tostring(#UpgradeGroups) .. " upgrade groups from workspace.")
	end
end

