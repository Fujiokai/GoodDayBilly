local function parseInterval(str, fallback)
	if not str then return fallback end
	str = string.lower(str)
	str = string.gsub(str, "%s+", "")
	if #str == 0 then return fallback end

	if str:sub(-2) == "ms" then
		local num = tonumber(str:sub(1, -3))
		if num and num > 0 then return num / 1000 end
	else
		local num = tonumber(str)
		if num and num > 0 then return num end
	end
	return fallback
end

