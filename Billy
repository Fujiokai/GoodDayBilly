	if autoGiveFireEnabled     then table.insert(active, "GiveFire") end
	if autoMagmaEnabled        then table.insert(active, "Magma") end
	if autoBlossomsEnabled     then table.insert(active, "Blossoms") end

	for _, name in ipairs(getActiveUpgradeGroupNames()) do
