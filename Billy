local function saveConfigToFile(saveName)
	if not hasFS() then
		warn("[Config] writefile/readfile not available.")
		return false, "File system not available"
	end

	ensureFolder()
	local safeName = saveName:gsub("[^%w_%-]", "_")
	if safeName == "" then
		return false, "Invalid save name"
	end

	local dataRunes = {}
	for _, r in ipairs(currentRunes) do
		if type(r) == "table" and type(r.name) == "string" then
			table.insert(dataRunes, { name = r.name, enabled = (r.enabled ~= false) })
		elseif type(r) == "string" then
			table.insert(dataRunes, { name = r, enabled = true })
		end
	end

	local upgradeGroupsConfig = {}
	for _, g in ipairs(UpgradeGroups) do
		upgradeGroupsConfig[g.id] = { enabled = g.enabled and true or false }
	end

	local config = {
		runes = dataRunes,
		intervals = {
			give      = giveInterval,
			upgrades  = upgradeInterval,
			tree      = upgradeTreeInterval,
			rune      = runeInterval,
			rebirth   = rebirthInterval,
			rarity    = rarityInterval,
			bamboo    = bambooInterval,
			everbloom = everBloomInterval,
			fish      = fishInterval,
		},
		toggles = {
			autoGive        = autoGiveEnabled,
			autoGiveFire    = autoGiveFireEnabled,
			autoMagma       = autoMagmaEnabled,
			autoBlossoms    = autoBlossomsEnabled,
			autoUpgradeTree = autoUpgradeTreeEnabled,
			autoRunes       = autoRunesEnabled,
			autoRebirth     = autoRebirthEnabled,
			autoAscend      = autoAscendEnabled,
			autoRarityRoll  = autoRarityRollEnabled,
			autoBamboo      = autoBambooEnabled,
			autoEverBloom   = autoEverBloomEnabled,
			autoFish        = autoFishEnabled,
		},
		upgradeGroups = upgradeGroupsConfig,
	}

	local path = SAVE_FOLDER .. "/" .. safeName .. SAVE_EXT
	local data = HttpService:JSONEncode(config)

	local ok, err = pcall(function()
		writefile(path, data)
	end)

	if not ok then
		return false, err
	end

	lastSaveName = safeName
	return true
end

local function applyConfigTable(config)
	-- Runes
	if type(config.runes) == "table" then
		local newList = {}
		for _, v in ipairs(config.runes) do
			if type(v) == "table" and type(v.name) == "string" then
				table.insert(newList, {
					name    = v.name,
					enabled = (v.enabled ~= false),
				})
			elseif type(v) == "string" then
				table.insert(newList, { name = v, enabled = true })
			end
		end
		currentRunes = newList
	end

	-- Intervals
	if type(config.intervals) == "table" then
		if type(config.intervals.give) == "number" then
			giveInterval = config.intervals.give
			if giveIntervalRow then giveIntervalRow.Set(giveInterval) end
		end
		if type(config.intervals.upgrades) == "number" then
			upgradeInterval = config.intervals.upgrades
			if upgradeIntervalRow then upgradeIntervalRow.Set(upgradeInterval) end
		end
		if type(config.intervals.tree) == "number" then
			upgradeTreeInterval = config.intervals.tree
			if treeIntervalRow then treeIntervalRow.Set(upgradeTreeInterval) end
		end
		if type(config.intervals.rune) == "number" then
			runeInterval = config.intervals.rune
			if runeIntervalRow then runeIntervalRow.Set(runeInterval) end
		end
		if type(config.intervals.rebirth) == "number" then
			rebirthInterval = config.intervals.rebirth
			if rebirthIntervalRow then rebirthIntervalRow.Set(rebirthInterval) end
		end
		if type(config.intervals.rarity) == "number" then
			rarityInterval = config.intervals.rarity
			if rarityIntervalRow then rarityIntervalRow.Set(rarityInterval) end
		end
		if type(config.intervals.bamboo) == "number" then
			bambooInterval = config.intervals.bamboo
			if bambooIntervalRow then bambooIntervalRow.Set(bambooInterval) end
		end
		if type(config.intervals.everbloom) == "number" then
			everBloomInterval = config.intervals.everbloom
			if everBloomIntervalRow then everBloomIntervalRow.Set(everBloomInterval) end
		end
		if type(config.intervals.fish) == "number" then
			fishInterval = config.intervals.fish
			if fishIntervalRow then fishIntervalRow.Set(fishInterval) end
		end
	end

	-- Toggles
	if type(config.toggles) == "table" then
		if autoGiveToggle and type(config.toggles.autoGive) == "boolean" then
			autoGiveToggle.Set(config.toggles.autoGive)
		end
		if autoGiveFireToggle and type(config.toggles.autoGiveFire) == "boolean" then
			autoGiveFireToggle.Set(config.toggles.autoGiveFire)
		end
		if autoMagmaToggle and type(config.toggles.autoMagma) == "boolean" then
			autoMagmaToggle.Set(config.toggles.autoMagma)
		end
		if autoBlossomsToggle and type(config.toggles.autoBlossoms) == "boolean" then
			autoBlossomsToggle.Set(config.toggles.autoBlossoms)
		end
		if autoUpgradeTreeToggle and type(config.toggles.autoUpgradeTree) == "boolean" then
			autoUpgradeTreeToggle.Set(config.toggles.autoUpgradeTree)
		end
		if autoRunesToggle and type(config.toggles.autoRunes) == "boolean" then
			autoRunesToggle.Set(config.toggles.autoRunes)
		end
		if autoRebirthToggle and type(config.toggles.autoRebirth) == "boolean" then
			autoRebirthToggle.Set(config.toggles.autoRebirth)
		end
		if autoAscendToggle and type(config.toggles.autoAscend) == "boolean" then
			autoAscendToggle.Set(config.toggles.autoAscend)
		end
		if autoRarityToggle and type(config.toggles.autoRarityRoll) == "boolean" then
			autoRarityToggle.Set(config.toggles.autoRarityRoll)
		end
		if autoBambooToggle and type(config.toggles.autoBamboo) == "boolean" then
			autoBambooToggle.Set(config.toggles.autoBamboo)
		end
		if autoEverBloomToggle and type(config.toggles.autoEverBloom) == "boolean" then
			autoEverBloomToggle.Set(config.toggles.autoEverBloom)
		end
		if autoFishToggle and type(config.toggles.autoFish) == "boolean" then
			autoFishToggle.Set(config.toggles.autoFish)
		end
	end

	-- Upgrade groups
	if type(config.upgradeGroups) == "table" then
		for _, g in ipairs(UpgradeGroups) do
			local entry = config.upgradeGroups[g.id]
			if entry and type(entry.enabled) == "boolean" and g.toggle then
				g.toggle.Set(entry.enabled)
			end
		end
	end
end

local function loadConfigFromFile(path)
	if not hasFS() then
		warn("[Config] writefile/readfile not available.")
		return false, "File system not available"
	end

	local ok, result = pcall(function()
		local content = readfile(path)
		return HttpService:JSONDecode(content)
	end)

	if not ok or type(result) ~= "table" then
		return false, "Failed to decode save"
	end

	-- Old format (plain runes array)
	if result[1] ~= nil and result.runes == nil and result.intervals == nil then
		local newList = {}
		for _, v in ipairs(result) do
			if type(v) == "string" then
				table.insert(newList, { name = v, enabled = true })
			end
		end
		currentRunes = newList
	else
		applyConfigTable(result)
	end

	return true
end

