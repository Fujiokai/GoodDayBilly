--------------------------------------------------------
-- FILE HELPERS (exploit env)
--------------------------------------------------------

local function hasFS()
	return writefile ~= nil and readfile ~= nil
end

local function ensureFolder()
	if not isfolder or not makefolder then return end
	local ok, _ = pcall(function()
		if not isfolder(SAVE_FOLDER) then
			makefolder(SAVE_FOLDER)
		end
	end)
end

local function getSaveFiles()
	local saves = {}
	if not listfiles or not isfolder then
		return saves
	end

	local ok, result = pcall(function()
		if not isfolder(SAVE_FOLDER) then
			return {}
		end
		return listfiles(SAVE_FOLDER)
	end)

	if not ok or not result then
		return saves
	end

	for _, path in ipairs(result) do
		if path:sub(-#SAVE_EXT) == SAVE_EXT then
			local nameWithExt = path:match("([^/\\]+)$") or path
			local baseName = nameWithExt:gsub("%"..SAVE_EXT.."$", "")
			table.insert(saves, {
				name = baseName,
				path = path,
			})
		end
	end

	table.sort(saves, function(a, b)
		return a.name < b.name
	end)

	return saves
end

